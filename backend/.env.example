# =============================================================================
# El maestro del segundo turno — API
# Copia este archivo a .env y completa los valores. NUNCA commitees el .env real.
# En producción (Contabo VPS) inyecta estos valores como secretos del sistema
# (Docker secrets / variables del orquestador / archivo .env fuera del repo).
# =============================================================================

# --- Servidor ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Base de datos ---
# Producción: PostgreSQL. El docker-compose local levanta esta misma URL.
DATABASE_URL="postgresql://maestro:maestro@localhost:5432/maestro?schema=public"
# Pruebas con SQLite (requiere cambiar provider en schema.prisma y quitar enums):
# DATABASE_URL="file:./dev.db"

# --- Proveedor de WhatsApp ---
#   baileys = librería no oficial, vinculas escaneando un QR (sin Meta Business).
#             Ideal para piloto/clase. Usa un número de prueba.
#   cloud   = API oficial de Meta (webhook + firma). Requiere las WHATSAPP_* de abajo.
WHATSAPP_PROVIDER=baileys
# Carpeta donde Baileys guarda la sesión (para no re-escanear el QR cada vez).
WHATSAPP_SESSION_DIR=./wa-session

# --- WhatsApp Cloud API (Meta) — SOLO si WHATSAPP_PROVIDER=cloud ---
# Token que TÚ inventas y registras en Meta para el handshake del webhook (GET).
WHATSAPP_VERIFY_TOKEN=
# App Secret de la app de Meta. Se usa para validar la firma X-Hub-Signature-256.
WHATSAPP_APP_SECRET=
# Para ENVIAR mensajes (opcional en dry-run): si faltan, los mensajes se loguean.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Número de WhatsApp del maestro (don Fernando), destino del resumen diario.
# Formato E.164 sin '+': p.ej. 56987654321
MAESTRO_PHONE=56987654321

# --- Reglas de negocio ---
# Fracción de anticipo para confirmar un pedido (0.5 = 50%).
DEPOSIT_RATIO=0.5

# --- Cron del resumen diario ---
# Formato cron de 5 campos. Por defecto: 20:00 todos los días.
DAILY_SUMMARY_CRON="0 20 * * *"
TZ=America/Santiago

# --- Adaptador de planillas (Google Forms/Sheets) — opcional ---
# Si defines la URL, el resumen y las exportaciones se envían ahí (POST).
SHEETS_WEBHOOK_URL=
# Token compartido para autenticar la ingesta entrante desde Forms/Sheets.
SHEETS_INGEST_TOKEN=
