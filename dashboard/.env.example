# URL del backend REST (la API de backend/). En Vite las variables públicas
# DEBEN llevar el prefijo VITE_. NO pongas secretos aquí: todo lo VITE_ queda
# embebido en el bundle del navegador y es visible para cualquiera.
VITE_API_URL="http://localhost:3000"

# Base path del build:
#   - Vercel / dominio propio:  "/"
#   - GitHub Pages en subruta:  "/Inovacion-2/"  (nombre del repo)
VITE_BASE="/"
